# Copy this file to .env.local and fill in your values
# Never commit .env.local to git

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Sentry — optional locally; required on Vercel.
# DSN is captured from browser code (semi-public — Sentry treats it as such).
VITE_SENTRY_DSN=

# Source map upload (build-time only — never bundled). Generate at
# Sentry → User → Auth Tokens. Skip locally to silence plugin warnings.
SENTRY_AUTH_TOKEN=

# GIPHY GIF picker — optional. Client-side key (GIPHY issues public browser
# keys by design). Absent = the GIF button is hidden and the feature is off.
# Set this in .env.local locally AND in Vercel (Preview + Production) to enable.
# Get a key at https://developers.giphy.com/dashboard/
VITE_GIPHY_API_KEY=
